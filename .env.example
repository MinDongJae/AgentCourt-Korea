# 양형기준 검색 어시스턴트 환경변수 예시
# 실제 키는 .env 파일에 (git 추적 X)

# ─── 법제처 OPEN API ────────────────────────────
# https://open.law.go.kr 에서 신청 (영업일 3~5일 소요)
LAW_API_KEY=your_law_go_kr_email_id
LAW_API_BASE=https://www.law.go.kr/DRF

# ─── LLM API (택 1 이상) ────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key
# OPENAI_API_KEY=sk-your-key

# ─── 임베딩 모델 ────────────────────────────────
# openai | bge-m3 | local
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-large

# ─── 인덱스 경로 ────────────────────────────────
SENTENCING_PDF_PATH=data/sentencing_guideline_2025.pdf
INDEX_DIR=data

# ─── 동작 모드 ──────────────────────────────────
# real | mock — Mock은 API 키 없이 구조 동작 확인용
LAW_API_MODE=mock
